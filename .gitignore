# ========================================
# Humanofi — .gitignore
# ========================================

# ---- Dependencies ----
node_modules/
.pnp
.pnp.js

# ---- Build outputs ----
dist/
build/
.next/
out/
*.tsbuildinfo
target/
tests-compiled/

# ---- Environment variables (CRITICAL) ----
.env
.env.local
.env.*.local
*.env
apps/web/.env.local
apps/web/.env

# ---- Private documentation (internal only) ----
docs/

# ---- Solana / Anchor ----
programs/humanofi/target/
test-ledger/
.anchor/
*.so
*.keypair

# ---- Keys & Secrets (NEVER commit) ----
*.pem
*.key
*-keypair.json
id.json
deploy-keypair.json
wallet.json
*.secret

# ---- Supabase local ----
supabase/.temp/
supabase/.branches/

# ---- IDE ----
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.turbo/

# ---- Testing ----
coverage/
.nyc_output/

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Internal references ----
references/
