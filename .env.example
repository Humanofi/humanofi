# ========================================
# Humanofi — Environment Variables
# ========================================
# Copy this file to apps/web/.env.local and fill in your values.
# NEVER commit .env.local to version control.

# ---- Solana ----
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://your-rpc-endpoint
SOLANA_PROGRAM_ID=your-deployed-program-id

# ---- Privy (Wallet / Auth) ----
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ---- Didit Identity (KYC) ----
DIDIT_API_KEY=your-didit-api-key
DIDIT_WORKFLOW_ID=your-didit-workflow-id
DIDIT_WEBHOOK_SECRET=your-didit-webhook-secret

# ---- Helius (On-chain sync) ----
HELIUS_API_KEY=your-helius-api-key
HELIUS_WEBHOOK_SECRET=your-webhook-hmac-secret

# ---- HIUID (Identity Hashing) ----
# Generate: openssl rand -hex 32
HIUID_SECRET_PEPPER=your-64-char-random-hex-string

# ---- Humanofi Protocol ----
NEXT_PUBLIC_TREASURY_WALLET=your-treasury-public-key
HUMANOFI_FEE_BPS=200

# ---- Next.js ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret
